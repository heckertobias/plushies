# Passwort für den Login
AUTH_PASSWORD=sicheres-passwort-hier

# Geheimnis für Session-Cookie (mind. 32 Zeichen, zufällig generieren)
# z.B.: openssl rand -base64 32
SESSION_SECRET=hier-mindestens-32-zufaellige-zeichen!!

# Token für den iCal-Feed (wird als URL-Parameter übergeben)
# z.B.: openssl rand -hex 24
ICAL_TOKEN=hier-ein-zufaelliges-token
